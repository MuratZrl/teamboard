# Database
DATABASE_URL="postgresql://teamboard:teamboard_dev@localhost:5433/teamboard?schema=public"

# API
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
