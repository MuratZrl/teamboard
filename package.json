{
  "name": "teamboard",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:api": "turbo dev --filter=@teamboard/api",
    "dev:web": "turbo dev --filter=@teamboard/web",
    "db:migrate": "pnpm --filter @teamboard/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @teamboard/api exec prisma generate",
    "db:studio": "pnpm --filter @teamboard/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
}
