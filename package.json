{
  "name": "teamboard",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:api": "turbo dev --filter=@teamboard/api",
    "dev:web": "turbo dev --filter=@teamboard/web",
    "db:migrate": "pnpm --filter @teamboard/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @teamboard/api exec prisma generate",
    "db:studio": "pnpm --filter @teamboard/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
